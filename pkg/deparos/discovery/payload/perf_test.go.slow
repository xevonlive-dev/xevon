)

// =============================================================================
// PERFORMANCE TEST CONSTANTS
// =============================================================================

const (
	// Scale factors for different test levels
	ScaleSmall  = 100_000   // 100K - quick test
	ScaleMedium = 1_000_000 // 1M - standard test

	// Concurrency levels
	WorkersLow    = 10
	WorkersMedium = 50
	WorkersHigh   = 100
)

// =============================================================================
// MEMORY TRACKING UTILITIES
// =============================================================================

// MemStats captures memory state at a point in time.
type MemStats struct {
	HeapAlloc   uint64
	HeapInuse   uint64
	HeapObjects uint64
	StackInuse  uint64
	NumGC       uint32
	Timestamp   time.Time
}

func captureMemStats() MemStats {
	var m runtime.MemStats
	runtime.ReadMemStats(&m)
	return MemStats{
		HeapAlloc:   m.HeapAlloc,
		HeapInuse:   m.HeapInuse,
		HeapObjects: m.HeapObjects,
		StackInuse:  m.StackInuse,
		NumGC:       m.NumGC,
		Timestamp:   time.Now(),
	}
}

func (s MemStats) String() string {
	return fmt.Sprintf("HeapAlloc=%s HeapInuse=%s Objects=%d Stack=%s GCs=%d",
		formatBytes(s.HeapAlloc),
		formatBytes(s.HeapInuse),
		s.HeapObjects,
		formatBytes(s.StackInuse),
		s.NumGC)
}

func formatBytes(b uint64) string {
	const unit = 1024
	if b < unit {
		return fmt.Sprintf("%d B", b)
	}
	div, exp := uint64(unit), 0
	for n := b / unit; n >= unit; n /= unit {
		div *= unit
		exp++
	}
	return fmt.Sprintf("%.2f %cB", float64(b)/float64(div), "KMGTPE"[exp])
}

