// TestPerf_ObservedProvider_100K tests with 100K operations.
func TestPerf_ObservedProvider_100K(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping performance test in short mode")
	}

	runPerformanceTest(t, "100K", ScaleSmall, WorkersLow, 0.5, DefaultMaxItems)
}

