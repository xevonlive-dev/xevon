(() => {
  const searchInput = document.getElementById("search-input")
  if (!searchInput) return;
  const url = new URL(window.location.href);
  const q = url.searchParams.get("q");
  if (url.pathname === "/search" && q) {
    searchInput.value = q;
  }
})();
