# Build stage
FROM golang:1.26-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        make \
        curl \
        unzip \
        file \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# bun is required by `make build` (compiles embedded archon + jsscan binaries).
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

# Force a static binary so it runs on the alpine (musl) runtime stage.
# sqliteshim falls back to the pure-go modernc.org/sqlite driver when CGO=0.
ENV CGO_ENABLED=0

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG TARGETOS
ARG TARGETARCH

RUN set -e; \
    target_os="${TARGETOS:-$(go env GOOS)}"; \
    target_arch="${TARGETARCH:-$(go env GOARCH)}"; \
    case "$target_arch" in \
        amd64) audit_arch="x64" ;; \
        arm64) audit_arch="arm64" ;; \
        *) echo "unsupported Docker target arch for xevon-audit: $target_arch" >&2; exit 1 ;; \
    esac; \
    audit_blob="platform/xevon-audit/build/dist/xevon-audit-${target_os}-${audit_arch}"; \
    if [ -f "$audit_blob" ]; then \
        bash build/scripts/stage-audit-blob.sh "$target_os" "$target_arch"; \
    else \
        echo "prebuilt $audit_blob not found; make build will rebuild xevon-audit"; \
    fi; \
    make ensure-jsscan \
    && make build \
    && mkdir -p /out \
    && cp bin/xevon /out/xevon

# Runtime stage
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

RUN adduser -D -u 1000 xevon

# Allow the bundled `claude` CLI to run without refusing on root-like
# environments by signalling a sandboxed context.
ENV IS_SANDBOX=1

COPY --from=builder /out/xevon /usr/local/bin/xevon

USER xevon
WORKDIR /home/xevon

ENTRYPOINT ["xevon"]
