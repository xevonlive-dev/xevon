{
  "name": "@xevon/xevon-audit",
  "version": "0.1.10-alpha",
  "private": true,
  "description": "xevon-audit — autonomous agent that performs thorough security audits on your codebase, part of xevon",
  "keywords": [
    "xevon",
    "security-audit",
    "codex",
    "claude",
    "claude-code",
    "agent-sdk",
    "anthropic",
    "openai"
  ],
  "homepage": "https://xevon.live",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xevonlive-dev/xevon-audit.git"
  },
  "bugs": {
    "url": "https://github.com/xevonlive-dev/xevon-audit/issues"
  },
  "author": "xevon",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "xevon-audit": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.ts",
    "build:all": "bun run build.ts --all",
    "transform": "bun run scripts/transform-content.ts",
    "release": "bun run scripts/release.ts",
    "release:dry": "XEVON_AUDIT_RELEASE_DRY_RUN=1 bun run scripts/release.ts",
    "npm-publish": "bun run scripts/npm-publish.ts",
    "npm-publish:dry": "XEVON_AUDIT_NPM_DRY_RUN=1 bun run scripts/npm-publish.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "lint:eslint": "eslint .",
    "preflight": "bun run typecheck && bun run lint && bun run lint:eslint && bun test && XEVON_AUDIT_BUILD_NO_INSTALL=1 bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "@openai/codex-sdk": "^0.130.0",
    "cac": "^6.7.14",
    "chalk": "^5.3.0",
    "yaml": "^2.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "eslint": "^10.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
