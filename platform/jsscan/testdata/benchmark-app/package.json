{
  "name": "benchmark-app",
  "version": "1.0.0",
  "description": "Test application for webpack extractor benchmarking",
  "main": "src/index.ts",
  "scripts": {
    "build:webpack5": "webpack --config configs/webpack5.config.js",
    "build:webpack4": "npx webpack-cli@4 --config configs/webpack4.config.js",
    "build:rollup": "rollup -c configs/rollup.config.mjs",
    "build:esbuild": "node configs/esbuild.config.js",
    "build:parcel": "parcel build src/index.ts --dist-dir dist/parcel --no-cache",
    "build:vite": "vite build --config configs/vite.config.ts",
    "build:all": "npm run build:webpack5 && npm run build:webpack4 && npm run build:rollup && npm run build:esbuild",
    "clean": "rm -rf dist/*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "esbuild": "^0.20.0",
    "parcel": "^2.12.0",
    "rollup": "^4.9.6",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.2.0"
  }
}
